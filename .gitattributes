# Git 属性配置 - 确保文本文件使用正确的换行符

# Shell 脚本必须使用 LF
*.sh text eol=lf

# Python 文件使用 LF
*.py text eol=lf

# 配置文件使用 LF
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Dockerfile 使用 LF
Dockerfile* text eol=lf
*.dockerfile text eol=lf

# Windows 批处理文件使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
